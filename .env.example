# ── Ticker Tracker environment ──────────────────────────────────────────────
# Copy to .env for local dev, or set these as Railway service variables.

# Database. Railway's Postgres plugin injects DATABASE_URL automatically.
# Locally, omit to use the bundled SQLite file (sqlite:///ticker.db).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Finnhub free-tier API key — enables REAL news + analyst ratings.
# Without it, those features fall back to deterministic mock data.
# Get one at https://finnhub.io/register
# FINNHUB_API_KEY=your_finnhub_key_here

# Port the server binds to. Railway sets this automatically.
# PORT=5000
