# ── Ticker Tracker environment ──────────────────────────────────────────────
# Copy to .env for local dev, or set these as Railway service variables.

# Database. Railway's Postgres plugin injects DATABASE_URL automatically.
# Locally, omit to use the bundled SQLite file (sqlite:///ticker.db).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Finnhub free-tier API key — enables REAL news + analyst ratings.
# Without it, those features fall back to deterministic mock data.
# Get one at https://finnhub.io/register
# FINNHUB_API_KEY=your_finnhub_key_here

# Port the server binds to. Railway sets this automatically.
# PORT=5000

# ── Auth ─────────────────────────────────────────────────────────────────────

# Signs sessions and tokens. Must be a long random string — never commit the real value.
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
# SECRET_KEY=change-me

# Google OAuth — register an OAuth app at https://console.cloud.google.com
# Authorized redirect URI: <APP_BASE_URL>/api/auth/google/callback
# Scopes required: openid, email, profile
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend (transactional email) — get a key at https://resend.com
# RESEND_API_KEY is your Resend API key.
# MAIL_FROM is the verified sender address, e.g. noreply@yourdomain.com
# RESEND_API_KEY=re_your_key_here
# MAIL_FROM=noreply@yourdomain.com

# Public base URL of the app — used for OAuth redirect URIs, email links, and
# the Secure cookie flag. No trailing slash. e.g. https://tickertracker.info
# APP_BASE_URL=https://tickertracker.info
